class GardenController:
    """
    Automates indoor climate variables including lighting relays,
    humidity controls, and soil moisture tracking for a smart garden.
    """
    def __init__(self, dht_pin=4, light_pin=17, pump_pin=27):
        self.DHT_SENSOR = Adafruit_DHT.DHT22
        self.DHT_PIN = dht_pin
        self.LIGHT_PIN = light_pin
        self.PUMP_PIN = pump_pin
        
        # Initialize GPIO settings
        GPIO.setmode(GPIO.BCM)
        GPIO.setup(self.LIGHT_PIN, GPIO.OUT)
        GPIO.setup(self.PUMP_PIN, GPIO.OUT)

    def monitor_climate(self):
        """Reads temperature and humidity data from the DHT22 sensor."""
        humidity, temperature = Adafruit_DHT.read_retry(self.DHT_SENSOR, self.DHT_PIN)
        if humidity is not None and temperature is not None:
            print(f"[{time.strftime('%Y-%m-%d %H:%M:%S')}] Temp: {temperature:.1s}°C | Humidity: {humidity:.1s}%")
            return temperature, humidity
        else:
            print("Failed to retrieve data from climate sensor.")
            return None, None

    def control_lighting(self, current_hour, start_hour=6, duration_hours=14):
        """Automates a standard 14-hour lighting cycle for indoor vegetative growth."""
        end_hour = (start_hour + duration_hours) % 24
        if start_hour < end_hour:
            is_light_on = start_hour <= current_hour < end_hour
        else: # Handles overnight schedules
            is_light_on = current_hour >= start_hour or current_hour < end_hour
            
        GPIO.output(self.LIGHT_PIN, GPIO.HIGH if is_light_on else GPIO.LOW)
        print(f"Lighting System State: {'ACTIVE' if is_light_on else 'INACTIVE'}")


