import time
import random

class StrawberryFiLedger:
    """Handles the immutable logging of genetic shifts and mutation success."""
    def __init__(self):
        self.ledger = []
    
    def record_mutation(self, plant_id, mutation_type, success_rate):
        entry = {
            "timestamp": time.strftime("%Y-%m-%d %H:%M:%S"),
            "plant_id": plant_id,
            "type": mutation_type,
            "success": f"{success_rate}%"
        }
        self.ledger.append(entry)
        print(f"[LEDGER SECURED] {mutation_type} recorded for {plant_id}.")

