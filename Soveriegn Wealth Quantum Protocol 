class QuantumFinancialSystem:
    def __init__(self, initial_principal, fiat_type="USD"):
        self.principal = initial_principal
        self.fiat = fiat_type
        self.growth_nodes = []

    def add_growth_strategy(self, name, annual_yield):
        """Adds a digital or traditional investment vector."""
        self.growth_nodes.append({"strategy": name, "yield": annual_yield})

    def simulate_quantum_growth(self, years):
        """
        Calculates growth using the 'Quantum Compounding' principle.
        Growth is not linear; it accelerates as digital utility increases.
        """
        total_balance = self.principal
        print(f"--- Initializing Financial Growth for {self.fiat} ---")
        
        for year in range(1, years + 1):
            # Aggregate yields from all nodes (Digital Assets + Traditional)
            total_yield = sum([node['yield'] for node in self.growth_nodes])
            
            # The 'Quantum' effect: Digital growth scales with network adoption
            network_multiplier = 1 + (year * 0.02) 
            total_balance *= (1 + (total_yield * network_multiplier))
            
            print(f"Year {year}: ${total_balance:,.2f} (Digital Efficiency Active)")
            
        return total_balance

