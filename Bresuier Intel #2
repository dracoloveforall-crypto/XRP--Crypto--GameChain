import os
import json
import time
import hashlib
from typing import Dict, Any, List

class CoreProjectOrchestrator:
    def __init__(self, node_id: str = "DRAC-CORE-002"):
        self.node_id = node_id
        self.registry: Dict[str, Any] = {}
        self.is_active = True
        print(f"[SYSTEM INITIATED] Node {self.node_id} online and locking framework protocols.")

    def register_subsystem(self, system_name: str, config: Dict[str, Any]) -> bool:
        """Integrates a new project component into the unified framework."""
        if system_name in self.registry:
            print(f"[WARN] {system_name} already registered. Updating integrity layers.")
        
        self.registry[system_name] = {
            "config": config,
            "timestamp": time.time(),
            "integrity_hash": self._generate_hash(config)
        }
        print(f"[SUCCESS] Subsystem '{system_name}' securely linked.")
        return True

    def _generate_hash(self, data: Any) -> str:
        """Maintains structural integrity verification across data sets."""
        serialized = json.dumps(data, sort_keys=True)
        return hashlib.sha256(serialized.encode('utf-8')).hexdigest()

    def sync_matrix(self) -> Dict[str, str]:
        """Synchronizes and verifies the state of all active sub-modules."""
        status_report = {}
        for system, meta in self.registry.items():
            current_hash = self._generate_hash(meta["config"])
            if current_hash != meta["integrity_hash"]:
                status_report[system] = "CRITICAL: INTEGRITY MISMATCH"
            else:
                status_report[system] = "VERIFIED & SECURE"
        return status_report

