/*
 * PROJECT: CoolCore V1 - High-Efficiency DIY Refrigeration
 * GOAL: Low-cost, long-lasting food preservation with power filtering logic.
 * TARGET: Arduino Uno / ESP32 / Raspberry Pi Pico
 */

#include <DHT.h> // For high-precision temperature/humidity monitoring

// --- Pin Definitions ---
#define TEMP_SENSOR_PIN 2      // Internal fridge sensor
#define COMPRESSOR_RELAY 4     // Main cooling unit
#define ROBOTIC_FAN_PWM 9      // High-power micro-fan
#define POWER_SENSE_PIN A0     // Monitoring electrical "adulterants" (noise)
#define HEAT_SYNC_SENSE A1     // Monitoring filter temperature

// --- Configuration ---
const float TARGET_TEMP = 3.0; // 3°C (Optimum for minerals/vitamins)
const float HYSTERESIS = 0.5;  // Prevention of frequent cycling
const int NOISE_THRESHOLD = 800; // Threshold for "dirty" power filtering

void setup() {
  pinMode(COMPRESSOR_RELAY, OUTPUT);
  pinMode(ROBOTIC_FAN_PWM, OUTPUT);
  Serial.begin(9600);
}

void loop() {
  float currentTemp = readTemperature();
  int powerQuality = analogRead(POWER_SENSE_PIN);
  int filterHeat = analogRead(HEAT_SYNC_SENSE);

  // 1. ELECTROMAGNETIC ADULTERANT FILTER LOGIC
  // If input power is noisy or overheating is detected at the filter, 
  // throttle the system to protect the motor and save energy.
  if (powerQuality > NOISE_THRESHOLD || filterHeat > 400) {
    applyPowerDampening(); 
  }

  // 2. ROBOTIC FAN CONTROL (Uniform Air Distribution)
  // Smaller, more powerful air movement prevents "hot zones"
  if (currentTemp > TARGET_TEMP) {
    analogWrite(ROBOTIC_FAN_PWM, 255); // Full blast for rapid cooling
  } else {
    analogWrite(ROBOTIC_FAN_PWM, 120); // Low-energy circulation mode
  }

  // 3. COMPRESSOR MANAGEMENT (Long-lasting quality)
  manageCooling(currentTemp);

  delay(2000); // 2-second check-in cycle
}

void manageCooling(float temp) {
  if (temp > (TARGET_TEMP + HYSTERESIS)) {
    digitalWrite(COMPRESSOR_RELAY, HIGH); // Start cooling
  } else if (temp < (TARGET_TEMP - HYSTERESIS)) {
    digitalWrite(COMPRESSOR_RELAY, LOW);  // Reach target, save power
  }
}

void applyPowerDampening() {
  // Logic to simulate an EMI filter's effect by reducing draw
  // when "electrical adulterants" or heat are detected.
  digitalWrite(COMPRESSOR_RELAY, LOW);
  analogWrite(ROBOTIC_FAN_PWM, 50); // Minimum safe operation
  Serial.println("WARNING: Adulterants detected. Filtering input...");
}

float readTemperature() {
  // Logic to pull from DHT sensor
  return 3.5; // Placeholder for demo
