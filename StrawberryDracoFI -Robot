import time
import random

class StrawberryFiEcosystem:
    """
    Merges StrawberryFi Utility Token, StrawberryFibot, and StrawberryFi Ledger.
    Manages funding for homeless relief and food distribution.
    """
    def __init__(self):
        self.token_name = "StrawberryFi Utility (SFU)"
        self.ledger_balance = 0.0
        self.total_food_funds = 0.0
        self.donation_history = []

    def process_utility_token(self, amount):
        # Syncing StrawberryFibot logic for automated transactions
        self.ledger_balance += amount
        print(f"[Ledger] {amount} {self.token_name} synced to global ledger.")

    def allocate_homeless_relief(self, amount):
        if self.ledger_balance >= amount:
            self.ledger_balance -= amount
            self.total_food_funds += amount
            self.donation_history.append({"amount": amount, "timestamp": time.time()})
            print(f"[Relief] Allocated {amount} SFU for food funding.")
        else:
            print("[Error] Insufficient StrawberryFi funds for donation.")


