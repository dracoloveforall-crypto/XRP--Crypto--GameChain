const StrawberryAgent = require('./agent');

const agents = [
  new StrawberryAgent("Guardian-1"),
  new StrawberryAgent("Watcher-2"),
  new StrawberryAgent("Analyzer-3")
];

function runSwarm(tx, decision) {
  return agents.map(agent => ({
    analysis: agent.analyze(tx),
    action: agent.act(decision)
  }));
}

module.exports = { runSwarm };





