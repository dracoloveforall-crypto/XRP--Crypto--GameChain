class StrawberryAgent {
  constructor(name) {
    this.name = name;
  }

  analyze(tx) {
    if (tx.amount > 100000) {
      return `${this.name}: High value transaction detected`;
    }
    return `${this.name}: Normal activity`;
  }

  act(decision) {
    if (decision === "BLOCK_TRANSACTION") {
      return `${this.name}: Blocking suspicious activity`;
    }
    return `${this.name}: Monitoring system`;
  }
}

module.exports = StrawberryAgent;





