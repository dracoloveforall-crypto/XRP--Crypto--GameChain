import datetime

class MycelialAegis:
    def __init__(self, rad_limit=0.4, moisture_target=65):
        self.rad_limit = rad_limit
        self.moisture_target = moisture_target
        self.seed_vault = []

    def seed_harvest(self, plant_health, species):
        """Proactive storage of elite genetics."""
        if plant_health > 90:
            timestamp = datetime.datetime.now()
            self.seed_vault.append({"type": species, "date": timestamp})
            return f"Secured {species} genetics in shielded vault."
        return "Monitoring growth for peak harvest window."

    def activate_emergency_sequence(self, sensor_rads):
        """Immediate environmental restoration trigger."""
        if sensor_rads >= self.rad_limit:
            return {
                "Action": "DEPLOYING SEED BOMBS",
                "Inventory": self.seed_vault,
                "Support": "Activating wall-misting and humidity controls"
            }
        return "Environment stable."

# Example: AI harvests seeds during good health, then deploys them during a spike
aegis = MycelialAegis()
print(aegis.seed_harvest(95, "Hyper-Accumulator Fungi"))
print(aegis.activate_emergency_sequence(0.75))
