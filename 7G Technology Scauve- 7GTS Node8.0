class StrawberryFiProtocol:
    """The Economic Engine: Utility token settlement."""
    def __init__(self, wallet_address):
        self.wallet = wallet_address
        self.balance_sfi = 0

    def mint_rewards(self, amount):
        self.balance_sfi += amount
        print(f"[StrawberryFi] Minted {amount} SFi to {self.wallet}")

class CoinbaseBridge:
    """The Off-Ramp: Converting SFi to USD/Stablecoin."""
    def convert_to_usd(self, sfi_amount):
        usd_value = sfi_amount * 1.0  # Pegged logic for $200/day target
        print(f"[Coinbase] Swapping {sfi_amount} SFi for ${usd_value} USD.")
        return usd_value

