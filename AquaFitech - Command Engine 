# 2. STRAWBERRYFI LEDGER: DeSci Data Integrity
# ==========================================
class StrawberryFiLedger:
    """
    A cryptographic ledger recording clean-up telemetry, providing proof-of-impact,
    and managing decentralized scientific validation data.
    """
    def __init__(self):
        self.chain: List[Dict[str, Any]] = []
        self.create_block(proof=100, previous_hash='0'*64, data="Genesis_DeSci_Ocean_Cleanup")

    def create_block(self, proof: int, previous_hash: str, data: Any) -> Dict[str, Any]:
        block = {
            'index': len(self.chain) + 1,
            'timestamp': time.time(),
            'proof': proof,
            'previous_hash': previous_hash,
            'data': data
        }
        block['hash'] = self._hash_block(block)
        self.chain.append(block)
        return block

    @staticmethod
    def _hash_block(block: Dict[str, Any]) -> str:
        encoded_block = json.dumps(block, sort_keys=True).encode()
        return hashlib.sha256(encoded_block).hexdigest()

    def log_cleanup_event(self, drone_id: str, telemetry: Dict[str, Any]):
        """Commits verified cleanup data directly to the StrawberryFi ledger."""
        prev_block = self.chain[-1]
        new_proof = prev_block['proof'] + 1 # Simplified Proof of Cleanup
        
        data_payload = {
            "drone_id": drone_id,
            "telemetry": telemetry,
            "desci_verification": "VALIDATED_BY_BIOSCIFI_AI"
        }
        
        new_block = self.create_block(new_proof, prev_block['hash'], data_payload)
        print(f"[StrawberryFi] Block #{new_block['index']} forged. Hash: {new_block['hash'][:16]}...")
        return new_block


