        self.num_qubits = num_qubits
        self.state_dim = 2 ** num_qubits
        self.state_vector = self._initialize_pure_state()

    def _initialize_pure_state(self) -> np.ndarray:
        """Initializes the quantum system to a uniform superposition state."""
        state = np.ones(self.state_dim, dtype=complex) / np.sqrt(self.state_dim)
        return state

    def apply_arbitrary_unitary(self, seed_matrix: np.ndarray) -> None:
        """
        Applies a custom, arbitrary unitary transformation matrix to the system.
        Ensures the matrix is rigorously unitary via QR decomposition.
        """
        if seed_matrix.shape != (self.state_dim, self.state_dim):
            # Fallback to generating a random unitary if dimensions mismatch
            seed_matrix = np.random.randn(self.state_dim, self.state_dim) + \
                          1j * np.random.randn(self.state_dim, self.state_dim)
        
        # QR decomposition to guarantee strict mathematical unitarity ($U^\dagger U = I$)
        Q, R = np.linalg.qr(seed_matrix)
        d = np.diagonal(R)
        ph = d / np.abs(d)
        unitary_matrix = Q * ph
        
        # Evolve the quantum state
        self.state_vector = np.dot(unitary_matrix, self.state_vector)

    def measure_probabilities(self) -> np.ndarray:
        """Collapses the quantum wave function into discrete probabilities."""
        return np.abs(self.state_vector) ** 2

