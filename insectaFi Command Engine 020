        self.is_running = True

    def apply_uv_bio_filter(self, frame):
        """Enhances biological fluorescence using UV spectrum simulation."""
        # Convert to LAB space to manipulate luminance and color channels
        lab = cv2.cvtColor(frame, cv2.COLOR_BGR2LAB)
        l, a, b = cv2.split(lab)
        
        # Boost the 'b' channel (blue-yellow) to highlight potential chitin/biologicals
        b = cv2.add(b, 50) 
        enhanced_lab = cv2.merge((l, a, b))
        uv_frame = cv2.cvtColor(enhanced_lab, cv2.COLOR_LAB2BGR)
        
        # Apply a purple/neon tint
        tint = np.full_like(uv_frame, (130, 0, 75)) # Deep Violet
        return cv2.addWeighted(uv_frame, 0.8, tint, 0.2, 0)

