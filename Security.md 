import requests
import json

# Configuration for your dracoloveforall account
GITHUB_TOKEN = 'your_personal_access_token'
REPO_OWNER = 'dracoloveforall'
REPO_NAME = 'NC-Tech-Advancement-Bridge'

def push_update_to_nc_hub(update_message, file_content):
    url = f"https://api.github.com/repos/{REPO_OWNER}/{REPO_NAME}/contents/LATEST_ADVANCEMENT.md"
    
    # Get the current file SHA to update it
    current_file = requests.get(url, headers={'Authorization': f'token {GITHUB_TOKEN}'})
    sha = current_file.json().get('sha', '')

    data = {
        "message": update_message,
        "content": file_content, # Must be base64 encoded
        "sha": sha
    }

    response = requests.put(url, headers={'Authorization': f'token {GITHUB_TOKEN}'}, data=json.dumps(data))
    
    if response.status_code == 200:
        print("Successfully broadcasted to NC Tech Hub.")
    else:
        print(f"Error: {response.text}")

