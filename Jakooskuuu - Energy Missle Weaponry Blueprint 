if __name__ == "__main__":
    print("--- Testing Jakcooskoo Systems Weapon Blueprint ---")
    
    # Initialize the weapon system
    launcher = JakcooskooLauncher()
    print(f"System Online: {launcher.weapon_name}\n")
    
    # Cycle 1: Charge and Fire
    print(launcher.initiate_charge())
    time.sleep(0.5) # Simulating charge lag
    
    fire_result = launcher.fire_missile(pilot_id="Pilot_Alpha_01")
    print(f"Telemetry Received:\n{fire_result}\n")
    
    # Extract missile ID to simulate impact tracking
    m_id = fire_result["projectile_data"]["missile_id"]
    print(f"Tracking missile [{m_id}] payload trajectory...")
    
    # Cycle 2: Impact / Detonation
    mock_missile = JakcooskooMissile(owner_id="Pilot_Alpha_01")
    impact_report = mock_missile.detonate()
    print(f"Impact Report:\n{impact_report}")


