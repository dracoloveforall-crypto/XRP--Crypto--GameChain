        detected_anomaly = random.choice(anomaly_types)
        severity = round(random.uniform(1.2, 5.8), 4)
        
        return {
            "layer": selected_layer,
            "anomaly": detected_anomaly,
            "entropy_score": severity,
            "timestamp": time.time()
        }

    def convert_errors_to_value(self, anomaly_data: Dict[str, Any]) -> Tuple[float, float]:
        """
        Extracts value from system chaos. Turns natural errors into utility value,
        empowering the 'value of time' by scaling unrealized financial gains.
        """
