import hashlib
import time

class StrawberryFiLedger:
    """The financial backbone for energy transactions and bot credits."""
    def __init__(self):
        self.chain = []
        self.market_price = 0.85  # Initial price per kWh in 'Berry' tokens

    def log_transaction(self, bot_id, energy_saved, market_status):
        record = {
            "timestamp": time.time(),
            "bot_id": bot_id,
            "savings": energy_saved,
            "market_drift": market_status,
            "hash": hashlib.sha256(str(time.time()).encode()).hexdigest()
        }
        self.chain.append(record)
        return f"Transaction Verified on StrawberryFi: {record['hash'][:10]}"

