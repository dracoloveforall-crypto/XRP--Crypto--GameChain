# ------------------------------------------------------------------------------
if __name__ == "__main__":
    nexus = MycelialWaterNexus()
    
    # 1. Pre-Catastrophe: Build atmospheric extraction grids
    nexus.sky_harvest_protocol(humidity_level=0.65)
    
