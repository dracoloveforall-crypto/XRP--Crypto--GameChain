class DualExtrusionSystem:
    """
    Controls the physical CNC/Gantry dual-nozzle matrix.
    Simultaneously extrudes structural high-durability steel alloy 
    and UV-stabilized impact-resistant vinyl compound.
    """
    def __init__(self, gantry_speed_mps: float = 2.5):
        self.gantry_speed = gantry_speed_mps  # Meters per second (High-speed)
        self.steel_nozzle_temp = 1550         # Celsius
        self.vinyl_nozzle_temp = 210          # Celsius
        self.feed_rate_modifier = 1.0

    def calculate_co_extrusion_pressure(self, layer_thickness_mm: float) -> dict:
        # Optimizes structural steel core with a protective, insulation-ready vinyl shell
        steel_psi = (layer_thickness_mm * 120) * self.feed_rate_modifier
        vinyl_psi = (layer_thickness_mm * 45) * self.feed_rate_modifier
        return {"steel_nozzle_psi": steel_psi, "vinyl_nozzle_psi": vinyl_psi}


