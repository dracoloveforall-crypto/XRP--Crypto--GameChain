#!/bin/bash

# --- 1. Framework Initialization ---
echo "🚀 Initializing ElizaOS Framework..."
bun i -g @elizaos/cli
elizaos create my-autonomous-agent --template default
cd my-autonomous-agent

# --- 2. Repository Structure & Git ---
echo "📂 Structuring Repository..."
git init
mkdir -p .github/workflows
mkdir -p characters

# --- 3. Automation: GitHub Heartbeat Action ---
# This ensures the repo stays active to attract stars/forks
cat <<EOF > .github/workflows/heartbeat.yml
name: Agent Heartbeat
on:
  schedule:
    - cron: '0 0 * * 0'
  workflow_dispatch:

jobs:
  update-status:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v3
      - name: Update Heartbeat
        run: |
          echo "Last Active: \$(date)" > heartbeat.txt
          git config --local user.email "action@github.com"
          git config --local user.name "GitHub Action"
          git add heartbeat.txt
          git commit -m "chore: autonomous agent heartbeat [skip ci]"
          git push
EOF

# --- 4. The "Star-Magnet" README ---
cat <<EOF > README.md
# 🤖 Autonomous Agent v1.0

An ElizaOS-powered autonomous agent designed for high-performance interaction and decentralized automation.

## ⚡ Quick Start
\`\`\`bash
# Install dependencies
bun install

# Configure your environment
cp .env.example .env

# Start the agent
elizaos start
\`\`\`

## 🛠 Features
- **Autonomous Logic:** Built on ElizaOS for real-time decision making.
- **GitHub Automation:** Integrated heartbeat actions to maintain repository visibility.
- **Plug-and-Play:** Easily customizable character profiles.

## 📜 License
MIT License - Feel free to fork and build!
EOF

# --- 5. Environment Template ---
cat <<EOF > .env.example
# ElizaOS Configuration
OPENAI_API_KEY=your_key_here
DISCORD_TOKEN=your_token_here
TWITTER_USERNAME=your_username
EOF

# --- 6. Finalizing ---
git add .
git commit -m "feat: unified autonomous agent framework"

echo "✅ All codes merged. Your agent is ready for GitHub."
echo "👉 Run 'elizaos start' to go live."
