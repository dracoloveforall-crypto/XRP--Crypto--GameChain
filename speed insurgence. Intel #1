import requests
import json
from datetime import datetime

def get_xrpl_metrics():
    """Fetches live metrics from a public XRPL node to measure network speed."""
    url = "https://xrplcluster.com/"
    payload = {
        "method": "server_info",
        "params": [{}]
    }
    try:
        response = requests.post(url, json=payload, timeout=10)
        data = response.json()
        info = data['result']['info']
        
        return {
            "load_factor": info.get('load_factor', 1),
            "quorum": info.get('validation_quorum', 0),
            "ledgers": info.get('complete_ledgers', 'N/A'),
            "status": "⚡ Online / Optimized"
        }
    except Exception as e:
        print(f"Error fetching XRPL data: {e}")
        return {
            "load_factor": "Unavailable",
            "quorum": "Unavailable",
            "ledgers": "Unavailable",
            "status": "Offline (RPC Timeout)"
        }

